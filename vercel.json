{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "^/api/claude$", "dest": "/api/claude" },
    { "src": "^/api/location-suggestions$", "dest": "/api/location-suggestions" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
